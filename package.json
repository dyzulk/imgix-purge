{
  "name": "imgix-cli-unofficial",
  "version": "1.0.2",
  "description": "A CLI tool to bulk purge all assets in an imgix Source cache.",
  "main": "dist/bin/imgix.js",
  "bin": {
    "imgix": "./bin/imgix.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "imgix": "node bin/imgix.js",
    "dev": "tsx src/bin/imgix.ts",
    "test": "node --import tsx --test e2e/*.test.ts",
    "test:e2e": "node --import tsx --test e2e/*.test.ts",
    "types:check": "tsc --noEmit",
    "link:local": "npm link --ignore-engines",
    "unlink:local": "npm rm --global imgix"
  },
  "keywords": [
    "imgix",
    "purge",
    "cache",
    "cdn",
    "bulk-purge",
    "cloudflare-r2"
  ],
  "author": "dyzulk",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dyzulk/imgix-cli-unofficial.git"
  },
  "bugs": {
    "url": "https://github.com/dyzulk/imgix-cli-unofficial/issues"
  },
  "homepage": "https://github.com/dyzulk/imgix-cli-unofficial#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "packageManager": "pnpm@11.5.3",
  "type": "module",
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "commander": "^15.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}

